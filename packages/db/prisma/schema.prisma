// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Core Models ====================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  passwordHash String
  displayName String?
  avatarUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  profiles  Profile[]
  teams     Team[]
  teamMembers TeamMember[]
  apiKeys   ApiKey[]
  integrations Integration[]
  activityLogs ActivityLog[]

  @@index([email])
  @@index([username])
}

model Profile {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  username  String   @unique
  title     String?
  description String?
  theme     String   @default("light")
  customDomain String? @unique
  backgroundColor String?
  textColor String?
  buttonStyle String?
  avatarUrl String?

  isPublished Boolean @default(false)
  viewCount   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  links         Link[]
  presets       Preset[]
  linkTimeouts  LinkTimeout[]
  campaigns     Campaign[]
  webhooks      Webhook[]
  visitorSessions VisitorSession[]
  analyticsSnapshots AnalyticsSnapshot[]
  swapHistories SwapHistory[]

  @@index([userId])
  @@index([username])
  @@index([customDomain])
}

model Link {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  title       String
  url         String
  shortUrl    String? @unique
  description String?
  position    Int?
  isActive    Boolean @default(true)
  iconUrl     String?
  buttonColor String?

  clickCount  Int     @default(0)
  revenueCents BigInt  @default(0)
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  clicks      LinkClick[]
  linkRevenue LinkRevenue[]
  linkTimeouts LinkTimeout[]
  presetLinks PresetLink[]
  swappedFromHistory SwapHistory[] @relation("fromLink")
  swappedToHistory   SwapHistory[] @relation("toLink")

  @@index([profileId])
  @@index([shortUrl])
  @@index([position])
}

model LinkClick {
  id        String   @id @default(cuid())
  linkId    String
  link      Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  timestamp   DateTime @default(now())
  visitorIpHash String?
  referrer    String?
  userAgent   String?
  country     String?
  city        String?
  deviceType  String?
  browser     String?
  os          String?
  dwellTimeMs Int?
  
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  sessionId   String?

  isBot       Boolean @default(false)

  @@index([linkId])
  @@index([profileId])
  @@index([timestamp])
  @@index([referrer])
  @@index([deviceType])
  @@index([country])
  @@index([sessionId])
}

model Preset {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  name        String
  description String?
  isActive    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  links     PresetLink[]
  campaigns CampaignStep[]
  scheduledActivations ScheduledActivation[]

  @@index([profileId])
}

model PresetLink {
  id       String @id @default(cuid())
  presetId String
  preset   Preset @relation(fields: [presetId], references: [id], onDelete: Cascade)
  
  linkId   String
  link     Link   @relation(fields: [linkId], references: [id], onDelete: Cascade)
  
  position Int

  @@unique([presetId, linkId])
  @@index([presetId])
}

model LinkTimeout {
  id        String   @id @default(cuid())
  linkId    String
  link      Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  timeoutType String
  expiresAt   DateTime?
  maxVisitorCount Int?
  visitorCountCurrent Int @default(0)
  
  fallbackLinkId String?
  
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())

  @@index([linkId])
  @@index([expiresAt])
  @@index([isActive])
}

model Campaign {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  name        String
  description String?
  status      String  @default("draft")

  createdAt   DateTime @default(now())
  startedAt   DateTime?
  endedAt     DateTime?

  steps       CampaignStep[]

  @@index([profileId])
  @@index([status])
}

model CampaignStep {
  id        String   @id @default(cuid())
  campaignId String
  campaign  Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  
  presetId  String?
  preset    Preset?  @relation(fields: [presetId], references: [id], onDelete: SetNull)

  stepNumber Int
  startsAt   DateTime?
  endsAt     DateTime?
  durationMinutes Int?
  orderIndex Int?

  createdAt DateTime @default(now())

  @@index([campaignId])
  @@index([startsAt])
}

model LinkRevenue {
  id        String   @id @default(cuid())
  linkId    String
  link      Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  transactionId String?
  source      String
  amountCents BigInt
  currency    String  @default("USD")
  attributionWindowHours Int @default(168)

  createdAt DateTime @default(now())

  @@index([linkId])
  @@index([profileId])
  @@index([createdAt])
  @@index([source])
}

model AnalyticsSnapshot {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  date      DateTime @unique

  totalClicks Int     @default(0)
  uniqueVisitors Int  @default(0)
  topReferrer String?
  topCountry  String?
  topDevice   String?
  topLinkId   String?
  revenueCents BigInt @default(0)

  createdAt DateTime @default(now())

  @@index([profileId])
  @@index([date])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  action      String
  resourceType String?
  resourceId  String?
  metadata    Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Integration {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  service     String
  accessToken String?
  refreshToken String?
  tokenExpiresAt DateTime?
  serviceAccountId String?
  metadata    Json?

  isConnected Boolean @default(true)
  lastSyncedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, service])
  @@index([userId])
  @@index([service])
}

model Webhook {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  eventType String
  url       String
  isActive  Boolean @default(true)
  secret    String?
  retryCount Int @default(3)

  createdAt DateTime @default(now())

  logs      WebhookLog[]

  @@index([profileId])
  @@index([eventType])
}

model WebhookLog {
  id        String   @id @default(cuid())
  webhookId String
  webhook   Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  eventData   Json?
  statusCode  Int?
  responseBody String?
  deliveredAt DateTime @default(now())
  nextRetryAt DateTime?

  @@index([webhookId])
  @@index([deliveredAt])
}

model Team {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  name      String

  createdAt DateTime @default(now())

  members   TeamMember[]

  @@index([ownerId])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  role      String   @default("member")

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String?
  keyHash   String   @unique
  lastUsedAt DateTime?

  createdAt DateTime @default(now())
  deletedAt DateTime?

  @@index([userId])
  @@index([keyHash])
}

model VisitorSession {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  sessionId String  @unique
  ipHash    String?
  referrer  String?
  deviceType String?
  country   String?

  firstVisit DateTime @default(now())
  lastVisit  DateTime @updatedAt
  clickCount Int     @default(0)
  linksClicked String[]

  @@index([profileId])
  @@index([sessionId])
  @@index([ipHash])
}

model SwapHistory {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  fromLinkId String
  fromLink   Link    @relation("fromLink", fields: [fromLinkId], references: [id], onDelete: Restrict)
  
  toLinkId   String
  toLink     Link    @relation("toLink", fields: [toLinkId], references: [id], onDelete: Restrict)

  swappedAt  DateTime @default(now())
  revertedAt DateTime?

  @@index([profileId])
  @@index([swappedAt])
}

model ScheduledActivation {
  id        String   @id @default(cuid())
  presetId  String
  preset    Preset   @relation(fields: [presetId], references: [id], onDelete: Cascade)

  scheduledFor DateTime
  jobId       String?
  status      String  @default("pending")
  errorMessage String?
  executedAt  DateTime?

  createdAt DateTime @default(now())

  @@index([presetId])
  @@index([scheduledFor])
  @@index([jobId])
  @@index([status])
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())

  @@index([email])
}
