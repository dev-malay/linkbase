-- Users table
CREATE TABLE users (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  email VARCHAR(255) UNIQUE NOT NULL,
  username VARCHAR(100) UNIQUE NOT NULL,
  password_hash VARCHAR(255) NOT NULL,
  display_name VARCHAR(255),
  avatar_url VARCHAR(500),
  created_at TIMESTAMP DEFAULT NOW(),
  updated_at TIMESTAMP DEFAULT NOW(),
  deleted_at TIMESTAMP,
  INDEX idx_email (email),
  INDEX idx_username (username)
);

-- Profiles (the link page)
CREATE TABLE profiles (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,
  username VARCHAR(100) UNIQUE NOT NULL,
  title VARCHAR(255),
  description TEXT,
  theme VARCHAR(50), -- 'light', 'dark', 'custom'
  custom_domain VARCHAR(255) UNIQUE,
  background_color VARCHAR(7), -- hex color
  text_color VARCHAR(7),
  button_style VARCHAR(50), -- 'rounded', 'sharp', 'pill'
  avatar_url VARCHAR(500),
  is_published BOOLEAN DEFAULT FALSE,
  view_count INT DEFAULT 0,
  created_at TIMESTAMP DEFAULT NOW(),
  updated_at TIMESTAMP DEFAULT NOW(),
  INDEX idx_user_id (user_id),
  INDEX idx_username (username),
  INDEX idx_custom_domain (custom_domain)
);

-- Links (individual links in profile)
CREATE TABLE links (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  profile_id UUID NOT NULL REFERENCES profiles(id) ON DELETE CASCADE,
  title VARCHAR(255) NOT NULL,
  url VARCHAR(2048) NOT NULL,
  short_url VARCHAR(50) UNIQUE, -- linkz.me/abc123
  description TEXT,
  position INT, -- order in profile (1, 2, 3, ...)
  is_active BOOLEAN DEFAULT TRUE,
  icon_url VARCHAR(500),
  button_color VARCHAR(7),
  click_count INT DEFAULT 0, -- denormalized for fast access
  revenue_cents BIGINT DEFAULT 0, -- total revenue in cents
  metadata JSONB, -- flexible storage: {category, tags, notes}
  created_at TIMESTAMP DEFAULT NOW(),
  updated_at TIMESTAMP DEFAULT NOW(),
  deleted_at TIMESTAMP,
  INDEX idx_profile_id (profile_id),
  INDEX idx_short_url (short_url),
  INDEX idx_position (profile_id, position)
);

-- Link clicks (analytics,)
CREATE TABLE link_clicks (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  link_id UUID NOT NULL REFERENCES links(id) ON DELETE CASCADE,
  profile_id UUID NOT NULL REFERENCES profiles(id) ON DELETE CASCADE,
  timestamp TIMESTAMP DEFAULT NOW(),
  visitor_ip_hash VARCHAR(64), -- hashed for privacy
  referrer VARCHAR(500), -- 'instagram', 'tiktok', 'youtube', 'direct', etc
  user_agent VARCHAR(500), -- browser info
  country VARCHAR(2), -- ISO country code
  city VARCHAR(100),
  device_type VARCHAR(50), -- 'mobile', 'desktop', 'tablet'
  browser VARCHAR(100), -- 'Chrome', 'Safari', etc
  os VARCHAR(100), -- 'iOS', 'Android', 'Windows', etc
  dwell_time_ms INT, -- how long on page before click (ms)
  utm_source VARCHAR(255),
  utm_medium VARCHAR(255),
  utm_campaign VARCHAR(255),
  session_id VARCHAR(64), -- group clicks by visitor session
  is_bot BOOLEAN DEFAULT FALSE, -- automated detection
  INDEX idx_link_id (link_id),
  INDEX idx_profile_id (profile_id),
  INDEX idx_timestamp (timestamp),
  INDEX idx_referrer (referrer),
  INDEX idx_device_type (device_type),
  INDEX idx_country (country),
  INDEX idx_session_id (session_id)
);

-- Presets ( link collections )
CREATE TABLE presets (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  profile_id UUID NOT NULL REFERENCES profiles(id) ON DELETE CASCADE,
  name VARCHAR(255) NOT NULL,
  description TEXT,
  link_ids UUID[], -- array of link IDs in order
  is_active BOOLEAN DEFAULT FALSE,
  created_at TIMESTAMP DEFAULT NOW(),
  updated_at TIMESTAMP DEFAULT NOW(),
  INDEX idx_profile_id (profile_id)
);

-- Scheduled link swaps
CREATE TABLE scheduled_swaps (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  profile_id UUID NOT NULL REFERENCES profiles(id) ON DELETE CASCADE,
  preset_id UUID REFERENCES presets(id) ON DELETE SET NULL,
  swap_type VARCHAR(50), -- 'preset', 'link', 'custom'
  target_links UUID[], -- which links to activate
  scheduled_for TIMESTAMP NOT NULL,
  job_id VARCHAR(255), -- BullMQ job ID for tracking
  status VARCHAR(50) DEFAULT 'pending', -- 'pending', 'completed', 'failed'
  error_message TEXT,
  executed_at TIMESTAMP,
  created_at TIMESTAMP DEFAULT NOW(),
  INDEX idx_profile_id (profile_id),
  INDEX idx_scheduled_for (scheduled_for),
  INDEX idx_job_id (job_id),
  INDEX idx_status (status)
);

-- link performance attribution (revenue tracking)
CREATE TABLE link_revenue (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  link_id UUID NOT NULL REFERENCES links(id) ON DELETE CASCADE,
  profile_id UUID NOT NULL REFERENCES profiles(id) ON DELETE CASCADE,
  transaction_id VARCHAR(255), -- from Stripe, Patreon, etc
  source VARCHAR(50), -- 'stripe', 'patreon', 'gumroad', 'youtube'
  amount_cents BIGINT NOT NULL, -- revenue in cents
  currency VARCHAR(3) DEFAULT 'USD', -- ISO code
  attribution_window_hours INT DEFAULT 168, -- 7 days
  created_at TIMESTAMP DEFAULT NOW(),
  INDEX idx_link_id (link_id),
  INDEX idx_profile_id (profile_id),
  INDEX idx_created_at (created_at),
  INDEX idx_source (source)
);

-- link timeouts (expiring links)
CREATE TABLE link_timeouts (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  link_id UUID NOT NULL REFERENCES links(id) ON DELETE CASCADE,
  profile_id UUID NOT NULL REFERENCES profiles(id) ON DELETE CASCADE,
  timeout_type VARCHAR(50), -- 'time-based', 'visitor-count', 'conditional'
  expires_at TIMESTAMP,
  max_visitor_count INT, -- null if time-based
  visitor_count_current INT DEFAULT 0, -- current count
  fallback_link_id UUID REFERENCES links(id) ON DELETE SET NULL, -- show this when timeout
  is_active BOOLEAN DEFAULT TRUE,
  created_at TIMESTAMP DEFAULT NOW(),
  INDEX idx_link_id (link_id),
  INDEX idx_expires_at (expires_at),
  INDEX idx_is_active (is_active)
);

-- campaigns for(multi-step link scheduling)
CREATE TABLE campaigns (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  profile_id UUID NOT NULL REFERENCES profiles(id) ON DELETE CASCADE,
  name VARCHAR(255) NOT NULL,
  description TEXT,
  status VARCHAR(50) DEFAULT 'draft', -- 'draft', 'scheduled', 'running', 'completed'
  created_at TIMESTAMP DEFAULT NOW(),
  started_at TIMESTAMP,
  ended_at TIMESTAMP,
  INDEX idx_profile_id (profile_id),
  INDEX idx_status (status)
);

-- campaign steps (each step in a multi-step campaign)
CREATE TABLE campaign_steps (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  campaign_id UUID NOT NULL REFERENCES campaigns(id) ON DELETE CASCADE,
  step_number INT NOT NULL,
  preset_id UUID REFERENCES presets(id) ON DELETE SET NULL,
  target_links UUID[], -- which links to show
  starts_at TIMESTAMP,
  ends_at TIMESTAMP,
  duration_minutes INT, -- if null, use explicit times above
  order_index INT,
  created_at TIMESTAMP DEFAULT NOW(),
  INDEX idx_campaign_id (campaign_id),
  INDEX idx_starts_at (starts_at)
);

-- ntegrations (connected external services)
CREATE TABLE integrations (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,
  service VARCHAR(50) NOT NULL, -- 'stripe', 'youtube', 'patreon', 'discord', etc
  access_token VARCHAR(1024),
  refresh_token VARCHAR(1024),
  token_expires_at TIMESTAMP,
  service_account_id VARCHAR(255), -- external service ID
  metadata JSONB, -- store service-specific data
  is_connected BOOLEAN DEFAULT TRUE,
  last_synced_at TIMESTAMP,
  created_at TIMESTAMP DEFAULT NOW(),
  updated_at TIMESTAMP DEFAULT NOW(),
  UNIQUE(user_id, service),
  INDEX idx_user_id (user_id),
  INDEX idx_service (service)
);

-- Webhooks (for campaign notifications, external events)
CREATE TABLE webhooks (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  profile_id UUID NOT NULL REFERENCES profiles(id) ON DELETE CASCADE,
  event_type VARCHAR(100) NOT NULL, -- 'link_clicked', 'campaign_completed', 'link_expired'
  url VARCHAR(2048) NOT NULL,
  is_active BOOLEAN DEFAULT TRUE,
  secret VARCHAR(255), -- for signing webhook payloads
  retry_count INT DEFAULT 3,
  created_at TIMESTAMP DEFAULT NOW(),
  INDEX idx_profile_id (profile_id),
  INDEX idx_event_type (event_type)
);

-- Webhook delivery logs (for debugging)
CREATE TABLE webhook_logs (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  webhook_id UUID NOT NULL REFERENCES webhooks(id) ON DELETE CASCADE,
  event_data JSONB,
  status_code INT,
  response_body TEXT,
  delivered_at TIMESTAMP DEFAULT NOW(),
  next_retry_at TIMESTAMP,
  INDEX idx_webhook_id (webhook_id),
  INDEX idx_delivered_at (delivered_at)
);

-- wl for the (for landing page)
CREATE TABLE waitlist (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  email VARCHAR(255) UNIQUE NOT NULL,
  name VARCHAR(255) NOT NULL,
  created_at TIMESTAMP DEFAULT NOW(),
  INDEX idx_email (email)
);

-- Analytics snapshots (daily aggregates)
CREATE TABLE analytics_snapshots (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  profile_id UUID NOT NULL REFERENCES profiles(id) ON DELETE CASCADE,
  date DATE NOT NULL,
  total_clicks INT DEFAULT 0,
  unique_visitors INT DEFAULT 0,
  top_referrer VARCHAR(100),
  top_country VARCHAR(2),
  top_device VARCHAR(50),
  top_link_id UUID,
  revenue_cents BIGINT DEFAULT 0,
  created_at TIMESTAMP DEFAULT NOW(),
  UNIQUE(profile_id, date),
  INDEX idx_profile_id (profile_id),
  INDEX idx_date (date)
);

-- User activity logs (for audit trail)
CREATE TABLE activity_logs (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,
  action VARCHAR(255), -- 'link_created', 'preset_activated', 'campaign_started'
  resource_type VARCHAR(50), -- 'link', 'preset', 'campaign'
  resource_id UUID,
  metadata JSONB,
  created_at TIMESTAMP DEFAULT NOW(),
  INDEX idx_user_id (user_id),
  INDEX idx_action (action),
  INDEX idx_created_at (created_at)
);

-- teams (for future multi-user support)
CREATE TABLE teams (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  name VARCHAR(255) NOT NULL,
  owner_id UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,
  created_at TIMESTAMP DEFAULT NOW(),
  INDEX idx_owner_id (owner_id)
);

-- Team members
CREATE TABLE team_members (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  team_id UUID NOT NULL REFERENCES teams(id) ON DELETE CASCADE,
  user_id UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,
  role VARCHAR(50) DEFAULT 'member', -- 'owner', 'admin', 'member'
  UNIQUE(team_id, user_id),
  INDEX idx_team_id (team_id),
  INDEX idx_user_id (user_id)
);

-- APIs keys (for SDK/API access)
CREATE TABLE api_keys (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,
  name VARCHAR(255),
  key_hash VARCHAR(255) UNIQUE NOT NULL, -- hashed for security
  last_used_at TIMESTAMP,
  created_at TIMESTAMP DEFAULT NOW(),
  deleted_at TIMESTAMP,
  INDEX idx_user_id (user_id),
  INDEX idx_key_hash (key_hash)
);

-- Visitor sessions (for personalization)
CREATE TABLE visitor_sessions (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  profile_id UUID NOT NULL REFERENCES profiles(id) ON DELETE CASCADE,
  session_id VARCHAR(64) UNIQUE NOT NULL,
  ip_hash VARCHAR(64),
  referrer VARCHAR(500),
  device_type VARCHAR(50),
  country VARCHAR(2),
  first_visit TIMESTAMP DEFAULT NOW(),
  last_visit TIMESTAMP DEFAULT NOW(),
  click_count INT DEFAULT 0,
  links_clicked UUID[], -- array of link IDs clicked
  INDEX idx_profile_id (profile_id),
  INDEX idx_session_id (session_id),
  INDEX idx_ip_hash (ip_hash)
);